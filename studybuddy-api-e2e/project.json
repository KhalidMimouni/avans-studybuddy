{
  "name": "studybuddy-api-e2e",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "implicitDependencies": ["studybuddy-api"],
  "projectType": "application",
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "studybuddy-api-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["studybuddy-api:build", "studybuddy-api:serve"]
    }
  }
}
